# Application
APP_NAME=Taxi Service API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
POSTGRES_USER=taxi
POSTGRES_PASSWORD=taxi_secret
POSTGRES_DB=taxi_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://taxi:taxi_secret@db:5432/taxi_db

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
